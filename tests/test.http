### Estado del servidor
GET https://json-beta-rose.vercel.app/

### Crear usuario
# @name crearUsuario
POST https://json-beta-rose.vercel.app/api/usuarios
Content-Type: application/json

{
  "nombre": "David Garcia",
  "email": "david.prueba@example.com",
  "password": "123456"
}

### Consultar usuarios
GET https://json-beta-rose.vercel.app/api/usuarios

### Actualizar usuario creado
PUT https://json-beta-rose.vercel.app/api/usuarios/{{crearUsuario.response.body.$.id_generado}}
Content-Type: application/json

{
  "nombre": "David Garcia Actualizado",
  "email": "david.actualizado@example.com",
  "password": "654321"
}

### Crear categoria
# @name crearCategoria
POST https://json-beta-rose.vercel.app/api/categorias
Content-Type: application/json

{
  "nombre": "Tecnologia",
  "descripcion": "Equipos y accesorios tecnologicos"
}

### Consultar categorias
GET https://json-beta-rose.vercel.app/api/categorias

### Actualizar categoria creada
PUT https://json-beta-rose.vercel.app/api/categorias/{{crearCategoria.response.body.$.id_generado}}
Content-Type: application/json

{
  "nombre": "Tecnologia y accesorios",
  "descripcion": "Equipos, componentes y accesorios tecnologicos"
}

### Crear producto usando la categoria creada
# @name crearProducto
POST https://json-beta-rose.vercel.app/api/productos
Content-Type: application/json

{
  "nombre": "Audifonos bluetooth",
  "precio": 85000,
  "categoria": "{{crearCategoria.response.body.$.id_generado}}",
  "stock": 10
}

### Consultar productos (incluye populate de categoria)
GET https://json-beta-rose.vercel.app/api/productos

### Actualizar producto creado
PUT https://json-beta-rose.vercel.app/api/productos/{{crearProducto.response.body.$.id_generado}}
Content-Type: application/json

{
  "nombre": "Audifonos bluetooth actualizados",
  "precio": 90000,
  "categoria": "{{crearCategoria.response.body.$.id_generado}}",
  "stock": 15
}

### Crear pedido
# @name crearPedido
POST https://json-beta-rose.vercel.app/api/pedidos
Content-Type: application/json

{
  "usuarioEmail": "david.actualizado@example.com",
  "productos": [
    {
      "productoId": "{{crearProducto.response.body.$.id_generado}}",
      "cantidad": 2
    }
  ],
  "total": 180000,
  "estado": "pendiente"
}

### Consultar pedidos
GET https://json-beta-rose.vercel.app/api/pedidos

### Actualizar pedido creado
PUT https://json-beta-rose.vercel.app/api/pedidos/{{crearPedido.response.body.$.id_generado}}
Content-Type: application/json

{
  "usuarioEmail": "david.actualizado@example.com",
  "productos": [
    {
      "productoId": "{{crearProducto.response.body.$.id_generado}}",
      "cantidad": 2
    }
  ],
  "total": 180000,
  "estado": "pagado"
}

### Actualizar solamente el estado del pedido
PATCH https://json-beta-rose.vercel.app/api/v1/actualizar-estado/{{crearPedido.response.body.$.id_generado}}
Content-Type: application/json

{
  "estado": "procesado"
}

### Eliminar pedido creado
DELETE https://json-beta-rose.vercel.app/api/pedidos/{{crearPedido.response.body.$.id_generado}}

### Eliminar producto creado
DELETE https://json-beta-rose.vercel.app/api/productos/{{crearProducto.response.body.$.id_generado}}

### Eliminar categoria creada
DELETE https://json-beta-rose.vercel.app/api/categorias/{{crearCategoria.response.body.$.id_generado}}

### Eliminar usuario creado
DELETE https://json-beta-rose.vercel.app/api/usuarios/{{crearUsuario.response.body.$.id_generado}}
